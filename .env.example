# Copy to .env and fill in your Cursor API key:
#   cp .env.example .env
#
# Generate a key at https://cursor.com/settings (headless / Docker use).

CURSOR_API_KEY=your_cursor_api_key_here
PORT=4646

# Optional: set to 1 for verbose Cursor CLI subprocess logs
# CURSOR_DEBUG=1

# --- Proxy auth (optional) -------------------------------------------------
# Leave both unset to keep the proxy open (local use, existing behavior).
#
# Two modes, selected by PROXY_AUTH_MODE (or inferred from PROXY_API_KEY):
#
# shared (default when PROXY_API_KEY is set):
#   Clients send  Authorization: Bearer <PROXY_API_KEY>
#   Cursor credentials come from the server (CURSOR_API_KEY / agent login).
#   Best for sharing your Cursor subscription via this proxy.
#
# bring-your-own-key:
#   Clients send  Authorization: Bearer <their own Cursor API Key>
#   The proxy only checks a real Bearer is present; validity is decided by
#   the Cursor CLI. Each user uses their own Cursor account.
#   Set PROXY_AUTH_MODE=bring-your-own-key (PROXY_API_KEY is not used).
#
# PROXY_API_KEY supports comma-separated values for key rotation.

# PROXY_API_KEY=sk-your-proxy-key-here
# PROXY_AUTH_MODE=shared
